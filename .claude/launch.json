{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Expo Dev Server",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "start"],
      "port": 8081
    },
    {
      "name": "Expo iOS",
      "runtimeExecutable": "sh",
      "runtimeArgs": ["-c", "LANG=en_US.UTF-8 npm run ios"],
      "port": 8081
    },
    {
      "name": "Expo Android",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "android"],
      "port": 8081
    }
  ]
}
